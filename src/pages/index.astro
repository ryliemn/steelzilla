---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ContactUs from "../components/contact-us";
import {
  SEATTLE_VAN_GOGH,
  ROUND_EAGLE_FLAG,
  STYX_GUITARS,
  GONE_SQUATCHIN,
} from "../utils/images";
---

<Layout>
  <div class="bg-zinc-100">
    <div class="relative">
      <Hero imgSrc={SEATTLE_VAN_GOGH.src} alt={SEATTLE_VAN_GOGH.alt} />
      <div
        class="absolute top-0 left-0 right-0 h-12 bg-linear-to-b from-white to-transparent"
      >
      </div>
      <div
        class="absolute bottom-0 left-0 right-0 h-12 bg-linear-to-t from-white to-transparent"
      >
      </div>
    </div>
    <div class="flex flex-col my-8 items-center space-y-4">
      <h1 class="text-2xl md:text-6xl font-bold text-zinc-900 text-center">
        METAL ART MONSTERS
      </h1>
      <div class="text-2xl text-zinc-900 text-center">
        CNC plasma cut, hand-finished metal artwork
      </div>
    </div>

    <div class="px-4 pb-8 max-w-4xl mx-auto w-full">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {
          [
            {
              href: "/gallery-usa",
              label: "USA",
              src: ROUND_EAGLE_FLAG.src,
              alt: ROUND_EAGLE_FLAG.alt,
            },
            {
              href: "/gallery-guitars-music",
              label: "Rock Stars & Guitars",
              src: STYX_GUITARS.src,
              alt: STYX_GUITARS.alt,
            },
            {
              href: "/gallery-pnw",
              label: "PNW Life",
              src: GONE_SQUATCHIN.src,
              alt: GONE_SQUATCHIN.alt,
            },
          ].map(({ href, label, src, alt }) => (
            <a
              href={href}
              class="group relative overflow-hidden rounded-xl shadow-md aspect-square block"
            >
              <img
                src={src}
                alt={alt}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent transition-opacity duration-300" />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300" />
              <div class="absolute bottom-0 left-0 right-0 p-3">
                <p class="text-white font-bold text-sm md:text-base leading-tight">
                  {label}
                </p>
                <p class="text-white/70 text-xs mt-0.5 flex items-center gap-1 translate-y-1 opacity-0 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
                  View gallery <span aria-hidden="true">→</span>
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </div>

    <ContactUs client:load />
  </div>
</Layout>
